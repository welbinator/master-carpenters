---
import { getEmDashCollection } from "emdash";

interface Props {
	node: {
		_key?: string;
		headline?: string;
		subheadline?: string;
		features: Array<{
			icon: string;
			title: string;
			description: string;
		}>;
	};
}

const { node } = Astro.props;
const { _key, headline, subheadline } = node;

// Fetch the first 6 gallery photos to preview on the homepage
const { entries: photos } = await getEmDashCollection("gallery", {
	status: "published",
	orderBy: { sort_order: "asc" },
	limit: 6,
});

type EmDashImage = { meta?: { storageKey?: string }; filename?: string } | null;
---

<section class="features section" id={_key}>
	<div class="container">
		{(headline || subheadline) && (
			<header class="section-header">
				{headline && <h2 class="section-headline">{headline}</h2>}
				{subheadline && <p class="section-subheadline">{subheadline}</p>}
			</header>
		)}

		{photos.length > 0 ? (
			<div class="preview-grid" id="features-preview-grid">
				{photos.map((photo, index) => {
					const img = photo.data.photo as EmDashImage;
					const storageKey = img?.meta?.storageKey;
					if (!storageKey) return null;
					const imgUrl = `/_emdash/api/media/file/${storageKey}`;
					return (
						<button
							type="button"
							class="preview-tile"
							data-src={imgUrl}
							data-caption={photo.data.caption as string || ""}
							data-index={index}
							aria-label={`View ${photo.data.caption as string || "photo"} full size`}
						>
							<img
								src={imgUrl}
								alt={photo.data.caption as string || "Master Carpenters project photo"}
								loading="lazy"
								decoding="async"
							/>
							<div class="preview-overlay">
								<span class="preview-caption">{photo.data.caption as string}</span>
							</div>
						</button>
					);
				})}
			</div>
		) : null}

		<div class="gallery-link-wrap">
			<a href="/gallery" class="btn btn-secondary btn-lg gallery-cta-link">
				View the Full Gallery &rarr;
			</a>
		</div>
	</div>
</section>

<script>
	// ── Lightbox for homepage preview grid ───────────────────────
	// Injected onto document.body to escape any CSS stacking context traps
	(function () {
		const grid = document.getElementById("features-preview-grid");
		if (!grid) return;

		// Build lightbox and append to body
		const lb = document.createElement("div");
		lb.id = "features-lightbox";
		lb.setAttribute("role", "dialog");
		lb.setAttribute("aria-modal", "true");
		lb.setAttribute("aria-label", "Image lightbox");
		lb.innerHTML = `
			<button class="flb-close" aria-label="Close lightbox">&times;</button>
			<button class="flb-prev" aria-label="Previous image">&#8249;</button>
			<button class="flb-next" aria-label="Next image">&#8250;</button>
			<div class="flb-inner">
				<img class="flb-img" src="" alt="" />
				<p class="flb-caption"></p>
			</div>
		`;
		lb.style.cssText = `
			display: none;
			position: fixed;
			inset: 0;
			z-index: 9999;
			background: rgba(0,0,0,0.92);
			align-items: center;
			justify-content: center;
		`;
		document.body.appendChild(lb);

		// Inject styles
		const style = document.createElement("style");
		style.textContent = `
			#features-lightbox.open { display: flex !important; }
			.flb-inner {
				max-width: 90vw;
				max-height: 90vh;
				display: flex;
				flex-direction: column;
				align-items: center;
			}
			.flb-inner .flb-img {
				max-width: 90vw;
				max-height: 80vh;
				object-fit: contain;
				border-radius: 8px;
				display: block;
			}
			.flb-caption {
				color: rgba(255,255,255,0.8);
				font-size: 0.9rem;
				margin-top: 0.75rem;
				text-align: center;
				min-height: 1.5em;
			}
			.flb-close {
				position: fixed;
				top: 1rem;
				right: 1.5rem;
				background: none;
				border: none;
				color: #fff;
				font-size: 2.5rem;
				line-height: 1;
				cursor: pointer;
				opacity: 0.8;
				z-index: 10000;
			}
			.flb-close:hover { opacity: 1; }
			.flb-prev, .flb-next {
				position: fixed;
				top: 50%;
				transform: translateY(-50%);
				background: rgba(255,255,255,0.1);
				border: none;
				color: #fff;
				font-size: 3rem;
				line-height: 1;
				padding: 0.5rem 1rem;
				cursor: pointer;
				border-radius: 6px;
				transition: background 0.2s;
				z-index: 10000;
			}
			.flb-prev { left: 1rem; }
			.flb-next { right: 1rem; }
			.flb-prev:hover, .flb-next:hover { background: rgba(255,255,255,0.25); }
		`;
		document.head.appendChild(style);

		const lbImg = lb.querySelector<HTMLImageElement>(".flb-img")!;
		const lbCaption = lb.querySelector<HTMLElement>(".flb-caption")!;
		const lbClose = lb.querySelector<HTMLButtonElement>(".flb-close")!;
		const lbPrev = lb.querySelector<HTMLButtonElement>(".flb-prev")!;
		const lbNext = lb.querySelector<HTMLButtonElement>(".flb-next")!;

		const tiles = Array.from(grid.querySelectorAll<HTMLButtonElement>(".preview-tile"));
		let currentIndex = 0;

		function showSlide(index: number) {
			currentIndex = (index + tiles.length) % tiles.length;
			const btn = tiles[currentIndex];
			lbImg.src = btn.dataset.src || "";
			lbImg.alt = btn.dataset.caption || "Master Carpenters project photo";
			lbCaption.textContent = btn.dataset.caption || "";
			lbPrev.style.display = tiles.length > 1 ? "" : "none";
			lbNext.style.display = tiles.length > 1 ? "" : "none";
		}

		function openLightbox(btn: HTMLButtonElement) {
			currentIndex = tiles.indexOf(btn);
			showSlide(currentIndex);
			lb.classList.add("open");
			document.body.style.overflow = "hidden";
			lbClose.focus();
		}

		function closeLightbox() {
			lb.classList.remove("open");
			document.body.style.overflow = "";
		}

		tiles.forEach((btn) => btn.addEventListener("click", () => openLightbox(btn)));
		lbClose.addEventListener("click", closeLightbox);
		lb.addEventListener("click", (e) => { if (e.target === lb) closeLightbox(); });
		lbPrev.addEventListener("click", () => showSlide(currentIndex - 1));
		lbNext.addEventListener("click", () => showSlide(currentIndex + 1));

		document.addEventListener("keydown", (e) => {
			if (!lb.classList.contains("open")) return;
			if (e.key === "Escape") closeLightbox();
			if (e.key === "ArrowLeft") showSlide(currentIndex - 1);
			if (e.key === "ArrowRight") showSlide(currentIndex + 1);
		});
	})();
</script>

<style>
	.preview-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--spacing-md);
		margin-bottom: var(--spacing-2xl);
	}

	.preview-tile {
		position: relative;
		display: block;
		border-radius: var(--radius-lg);
		overflow: hidden;
		aspect-ratio: 4 / 3;
		background: var(--color-surface);
		cursor: zoom-in;
		border: none;
		padding: 0;
	}

	.preview-tile img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		transition: transform 0.4s ease;
	}

	.preview-tile:hover img {
		transform: scale(1.05);
	}

	.preview-overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(to top, rgba(0,0,0,0.55) 0%, transparent 55%);
		display: flex;
		align-items: flex-end;
		padding: var(--spacing-md);
		opacity: 0;
		transition: opacity 0.3s ease;
	}

	.preview-tile:hover .preview-overlay {
		opacity: 1;
	}

	.preview-caption {
		color: #fff;
		font-size: var(--font-size-sm);
		font-weight: 500;
		line-height: 1.3;
	}

	.gallery-link-wrap {
		display: flex;
		justify-content: center;
	}

	.gallery-cta-link {
		font-weight: 600;
		border-color: var(--color-brand);
		color: var(--color-brand);
	}

	.gallery-cta-link:hover {
		background: color-mix(in srgb, var(--color-brand) 8%, transparent);
	}

	@media (max-width: 900px) {
		.preview-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 540px) {
		.preview-grid {
			grid-template-columns: 1fr 1fr;
			gap: var(--spacing-sm);
		}
	}
</style>
