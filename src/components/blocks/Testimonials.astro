---
interface Props {
	node: {
		headline?: string;
		testimonials: Array<{
			quote: string;
			author: string;
			role?: string;
			company?: string;
			avatar?: string;
		}>;
	};
}

const { node } = Astro.props;
const { headline, testimonials } = node;
---

<section class="testimonials section" id="reviews">
	<div class="container">
		{headline && (
			<header class="section-header">
				<h2 class="section-headline">{headline}</h2>
				<p class="section-subheadline">
					All reviews pulled directly from our Google Business listing. 5.0 stars.
				</p>
			</header>
		)}

		<div class="carousel-wrap">
			<div class="carousel" id="testimonials-carousel">
				{testimonials.map((t) => (
					<div class="testimonial-card">
						<div class="stars" aria-label="5 stars">
							<span>★</span><span>★</span><span>★</span><span>★</span><span>★</span>
						</div>
						<blockquote class="testimonial-quote">
							"{t.quote}"
						</blockquote>
						<div class="testimonial-author">
							{t.avatar && (
								<img src={t.avatar} alt={t.author} class="testimonial-avatar" loading="lazy" />
							)}
							<div class="testimonial-info">
								<span class="testimonial-name">{t.author}</span>
								{(t.role || t.company) && (
									<span class="testimonial-meta">
										{t.role}{t.role && t.company && " · "}{t.company}
									</span>
								)}
							</div>
						</div>
					</div>
				))}
			</div>

			<div class="carousel-controls">
				<button class="carousel-btn prev" id="carousel-prev" aria-label="Previous review" type="button">←</button>
				<div class="carousel-dots" id="carousel-dots"></div>
				<button class="carousel-btn next" id="carousel-next" aria-label="Next review" type="button">→</button>
			</div>
		</div>

		<div class="reviews-footer">
			<a
				href="https://maps.app.goo.gl/2vUvSxFykEqjqiM56"
				target="_blank"
				rel="noopener noreferrer"
				class="google-link"
			>
				View all 20+ reviews on Google →
			</a>
		</div>
	</div>
</section>

<script>
	const carousel = document.getElementById("testimonials-carousel");
	const dotsContainer = document.getElementById("carousel-dots");
	const prevBtn = document.getElementById("carousel-prev");
	const nextBtn = document.getElementById("carousel-next");

	if (carousel && dotsContainer) {
		const cards = carousel.querySelectorAll<HTMLElement>(".testimonial-card");
		let current = 0;
		let dots: HTMLButtonElement[] = [];

		function visibleCount(): number {
			const w = carousel!.offsetWidth;
			const cardW = (cards[0] as HTMLElement)?.offsetWidth || 340;
			const gap = 24;
			return Math.max(1, Math.floor((w + gap) / (cardW + gap)));
		}

		function totalStops(): number {
			return Math.max(1, cards.length - visibleCount() + 1);
		}

		function buildDots() {
			dotsContainer!.innerHTML = "";
			dots = [];
			const count = totalStops();
			for (let i = 0; i < count; i++) {
				const btn = document.createElement("button");
				btn.className = "dot" + (i === current ? " active" : "");
				btn.type = "button";
				btn.setAttribute("aria-label", `Go to review ${i + 1}`);
				btn.addEventListener("click", () => goTo(i));
				dotsContainer!.appendChild(btn);
				dots.push(btn);
			}
		}

		function goTo(index: number) {
			const stops = totalStops();
			// Loop around
			current = ((index % stops) + stops) % stops;
			const cardW = (cards[0] as HTMLElement)?.offsetWidth || 340;
			const gap = 24;
			carousel!.scrollTo({ left: current * (cardW + gap), behavior: "smooth" });
			dots.forEach((d, i) => d.classList.toggle("active", i === current));
		}

		prevBtn?.addEventListener("click", () => goTo(current - 1));
		nextBtn?.addEventListener("click", () => goTo(current + 1));

		// Rebuild dots on resize (visible count may change)
		const ro = new ResizeObserver(() => {
			buildDots();
			goTo(current);
		});
		ro.observe(carousel);

		buildDots();

		// Auto-advance every 5s
		let timer = setInterval(() => goTo(current + 1), 5000);
		carousel.addEventListener("mouseenter", () => clearInterval(timer));
		carousel.addEventListener("mouseleave", () => {
			timer = setInterval(() => goTo(current + 1), 5000);
		});
	}
</script>

<style>
	.testimonials {
		background: var(--color-surface);
	}

	.carousel-wrap {
		position: relative;
	}

	.carousel {
		display: flex;
		gap: 1.5rem;
		overflow-x: auto;
		scroll-snap-type: x mandatory;
		scrollbar-width: none;
		-webkit-overflow-scrolling: touch;
		padding-bottom: var(--spacing-sm);
	}

	.carousel::-webkit-scrollbar { display: none; }

	.testimonial-card {
		flex: 0 0 340px;
		scroll-snap-align: start;
		padding: var(--spacing-xl);
		background: var(--color-bg);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		display: flex;
		flex-direction: column;
		gap: var(--spacing-md);
	}

	.stars {
		display: flex;
		gap: 2px;
		color: #c9902a;
		font-size: 1.1rem;
	}

	.testimonial-quote {
		font-size: var(--font-size-base);
		line-height: 1.65;
		color: var(--color-text);
		flex: 1;
	}

	.testimonial-author {
		display: flex;
		align-items: center;
		gap: var(--spacing-md);
		padding-top: var(--spacing-sm);
		border-top: 1px solid var(--color-border);
	}

	.testimonial-avatar {
		width: 44px;
		height: 44px;
		border-radius: 50%;
		object-fit: cover;
		flex-shrink: 0;
	}

	.testimonial-info { display: flex; flex-direction: column; gap: 0.15rem; }

	.testimonial-name {
		font-size: var(--font-size-sm);
		font-weight: 600;
		color: var(--color-text);
	}

	.testimonial-meta {
		font-size: var(--font-size-xs);
		color: var(--color-muted);
	}

	/* Controls */
	.carousel-controls {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: var(--spacing-md);
		margin-top: var(--spacing-xl);
	}

	.carousel-btn {
		width: 40px;
		height: 40px;
		border-radius: 50%;
		border: 1px solid var(--color-border);
		background: var(--color-bg);
		color: var(--color-text);
		font-size: 1.1rem;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: all var(--transition-fast);
		flex-shrink: 0;
	}

	.carousel-btn:hover {
		background: var(--color-brand);
		color: #fff;
		border-color: var(--color-brand);
	}

	.carousel-dots {
		display: flex;
		gap: var(--spacing-xs);
		flex-wrap: wrap;
		justify-content: center;
	}

	:global(.dot) {
		width: 10px;
		height: 10px;
		border-radius: 50%;
		border: none;
		background: var(--color-muted, #aaa);
		opacity: 0.5;
		cursor: pointer;
		transition: background var(--transition-fast), transform var(--transition-fast), opacity var(--transition-fast);
		padding: 0;
		flex-shrink: 0;
	}

	:global(.dot.active) {
		background: var(--color-brand);
		opacity: 1;
		transform: scale(1.3);
	}

	:global(.dot:hover) {
		opacity: 0.75;
	}

	.reviews-footer {
		text-align: center;
		margin-top: var(--spacing-xl);
	}

	.google-link {
		font-size: var(--font-size-sm);
		color: var(--color-brand);
		font-weight: 500;
		text-decoration: underline;
		text-underline-offset: 3px;
	}

	.google-link:hover { color: var(--color-brand-strong); }
</style>
