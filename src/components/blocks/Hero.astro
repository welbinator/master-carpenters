---
interface Props {
	node: {
		headline: string;
		subheadline?: string;
		primaryCtaLabel?: string;
		primaryCtaUrl?: string;
		secondaryCtaLabel?: string;
		secondaryCtaUrl?: string;
		imageUrl?: string;
		centered?: boolean;
	};
}

const { node } = Astro.props;
const { headline, subheadline, centered } = node;

const primaryCta =
	node.primaryCtaLabel && node.primaryCtaUrl
		? { label: node.primaryCtaLabel, url: node.primaryCtaUrl }
		: undefined;
const secondaryCta =
	node.secondaryCtaLabel && node.secondaryCtaUrl
		? { label: node.secondaryCtaLabel, url: node.secondaryCtaUrl }
		: undefined;

// Use imageUrl from editor, fall back to placeholder
const heroImage = node.imageUrl || "/hero-placeholder.jpg";
---

<section class:list={["hero-section", { "hero-centered": centered }]}>
	<div class="hero-inner">
		<!-- Left: text content -->
		<div class="hero-content">
			<div class="hero-badge">
				<span class="badge-dot"></span>
				Cedar Rapids, Iowa
			</div>

			<h1 class="hero-headline">{headline}</h1>

			{subheadline && <p class="hero-subheadline">{subheadline}</p>}

			<!-- Star rating row -->
			<div class="hero-social-proof">
				<div class="star-row" aria-label="5 stars">
					{"★★★★★".split("").map(() => <span class="star">★</span>)}
				</div>
				<span class="proof-text">Rated 5 stars · 20+ Google reviews</span>
			</div>

			{(primaryCta || secondaryCta) && (
				<div class="hero-actions">
					{primaryCta && (
						<a href={primaryCta.url} class="btn btn-primary btn-lg">
							{primaryCta.label}
						</a>
					)}
					{secondaryCta && (
						<a href={secondaryCta.url} class="btn btn-outline btn-lg">
							{secondaryCta.label}
						</a>
					)}
				</div>
			)}
		</div>

		<!-- Right: image with floating badge -->
		<div class="hero-media">
			<div class="hero-img-wrap">
				<img
					src={heroImage}
					alt="Master Carpenters deck and exterior work"
					class="hero-img"
					loading="eager"
					width="680"
					height="520"
				/>
				<!-- Floating callout card -->
				<div class="hero-callout">
					<span class="callout-num">10+</span>
					<span class="callout-label">Years of craftsmanship</span>
				</div>
				<!-- Subtle wood-grain accent bar -->
				<div class="hero-accent-bar"></div>
			</div>
		</div>
	</div>
</section>

<style>
	.hero-section {
		background: var(--color-bg);
		padding: var(--spacing-5xl) 0 var(--spacing-4xl);
		overflow: hidden;
	}

	.hero-inner {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: 0 var(--spacing-lg);
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--spacing-4xl);
		align-items: center;
	}

	/* ── Badge ── */
	.hero-badge {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		background: color-mix(in srgb, var(--color-brand) 10%, transparent);
		color: var(--color-brand);
		border: 1px solid color-mix(in srgb, var(--color-brand) 25%, transparent);
		border-radius: 999px;
		padding: 0.3rem 0.85rem;
		font-size: var(--font-size-xs);
		font-weight: 600;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		width: fit-content;
	}

	.badge-dot {
		width: 7px;
		height: 7px;
		border-radius: 50%;
		background: var(--color-brand);
		flex-shrink: 0;
		box-shadow: 0 0 0 2px color-mix(in srgb, var(--color-brand) 30%, transparent);
	}

	/* ── Headline ── */
	.hero-content {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-lg);
	}

	.hero-headline {
		font-size: clamp(2.4rem, 4vw, 3.5rem);
		font-weight: var(--font-weight-display);
		line-height: 1.1;
		letter-spacing: -0.03em;
		color: var(--color-text);
		max-width: 14ch;
	}

	.hero-subheadline {
		font-size: var(--font-size-lg);
		line-height: 1.65;
		color: var(--color-muted);
		max-width: 46ch;
	}

	/* ── Social proof ── */
	.hero-social-proof {
		display: flex;
		align-items: center;
		gap: var(--spacing-md);
	}

	.star-row {
		display: flex;
		gap: 1px;
	}

	.star {
		color: #c9902a;
		font-size: 1.1rem;
	}

	.proof-text {
		font-size: var(--font-size-sm);
		color: var(--color-muted);
		font-weight: 500;
	}

	/* ── CTAs ── */
	.hero-actions {
		display: flex;
		gap: var(--spacing-md);
		flex-wrap: wrap;
		margin-top: var(--spacing-xs);
	}

	.btn-outline {
		background: transparent;
		border: 1.5px solid var(--color-brand);
		color: var(--color-brand);
		font-weight: 600;
	}

	.btn-outline:hover {
		background: color-mix(in srgb, var(--color-brand) 8%, transparent);
	}

	/* ── Image panel ── */
	.hero-media {
		position: relative;
	}

	.hero-img-wrap {
		position: relative;
		border-radius: var(--radius-lg);
		overflow: visible;
	}

	.hero-img {
		width: 100%;
		height: 480px;
		object-fit: cover;
		border-radius: var(--radius-lg);
		display: block;
		box-shadow:
			0 2px 4px rgba(0,0,0,.06),
			0 8px 32px rgba(0,0,0,.12),
			0 24px 64px rgba(0,0,0,.10);
	}

	/* Floating "10+ Years" card */
	.hero-callout {
		position: absolute;
		bottom: -1.5rem;
		left: -1.75rem;
		background: var(--color-bg);
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		padding: 0.85rem 1.25rem;
		display: flex;
		flex-direction: column;
		gap: 0.1rem;
		box-shadow: 0 4px 24px rgba(0,0,0,.10);
		min-width: 130px;
	}

	.callout-num {
		font-size: 1.9rem;
		font-weight: 800;
		line-height: 1;
		color: var(--color-brand);
		letter-spacing: -0.04em;
	}

	.callout-label {
		font-size: var(--font-size-xs);
		color: var(--color-muted);
		font-weight: 500;
		line-height: 1.3;
		max-width: 10ch;
	}

	/* Decorative accent bar bottom-right */
	.hero-accent-bar {
		position: absolute;
		bottom: -6px;
		right: -6px;
		width: 60%;
		height: 6px;
		border-radius: 0 0 var(--radius-lg) 0;
		background: var(--gradient-brand);
		opacity: 0.8;
	}

	/* ── Centered variant ── */
	.hero-centered .hero-inner {
		grid-template-columns: 1fr;
		max-width: var(--max-width);
		text-align: center;
	}

	.hero-centered .hero-badge,
	.hero-centered .hero-social-proof {
		justify-content: center;
		margin-left: auto;
		margin-right: auto;
	}

	.hero-centered .hero-actions { justify-content: center; }
	.hero-centered .hero-headline { max-width: none; }
	.hero-centered .hero-subheadline { margin: 0 auto; }

	/* ── Responsive ── */
	@media (max-width: 1024px) {
		.hero-inner {
			grid-template-columns: 1fr;
			gap: var(--spacing-3xl);
		}

		.hero-media { order: -1; }

		.hero-img { height: 360px; }

		.hero-callout {
			bottom: -1rem;
			left: -0.75rem;
		}

		.hero-headline { max-width: none; font-size: clamp(2rem, 5vw, 3rem); }

		.hero-content { text-align: center; align-items: center; }
		.hero-badge { align-self: center; }
		.hero-social-proof { justify-content: center; }
		.hero-actions { justify-content: center; }
		.hero-subheadline { margin: 0 auto; }
	}

	@media (max-width: 640px) {
		.hero-section { padding: var(--spacing-3xl) 0 var(--spacing-4xl); }
		.hero-img { height: 280px; }
		.hero-callout { display: none; }
		.hero-headline { font-size: 2rem; }
	}
</style>
