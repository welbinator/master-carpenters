---
import { getEmDashCollection } from "emdash";
import Base from "../layouts/Base.astro";

// Query all published gallery photos, ordered by sort_order
const { entries: photos, cacheHint } = await getEmDashCollection("gallery", {
	status: "published",
	orderBy: { sort_order: "asc" },
	limit: 100,
});

if (Astro.cache?.enabled) Astro.cache.set(cacheHint);

// Group by category for filter tabs
const categories = ["All", ...new Set(photos.map((p) => p.data.category || "General").filter(Boolean))];
---

<Base
	title="Gallery"
	description="See our work — Master Carpenters deck and siding projects across Cedar Rapids, Iowa."
>
	<section class="gallery-hero section">
		<div class="container">
			<header class="section-header">
				<h1 class="section-headline">Our Work</h1>
				<p class="section-subheadline">
					Every project is a reflection of the care Layne and his crew put into the job.
					Browse our recent decks, siding, and exterior work below.
				</p>
			</header>

			{photos.length > 0 ? (
				<>
					<!-- Filter bar -->
					{categories.length > 2 && (
						<div class="filter-bar" id="filter-bar">
							{categories.map((cat) => (
								<button
									class={`filter-btn ${cat === "All" ? "active" : ""}`}
									data-category={cat}
									type="button"
								>
									{cat}
								</button>
							))}
						</div>
					)}

					<!-- Photo grid -->
					<div class="photo-grid" id="photo-grid">
						{photos.map((photo, index) => {
							type EmDashImage = { meta?: { storageKey?: string }; filename?: string } | null;
							const img = photo.data.photo as EmDashImage;
							const storageKey = img?.meta?.storageKey;
							if (!storageKey) return null;
							const imgUrl = `/_emdash/api/media/file/${storageKey}`;
							return (
								<figure
									class="photo-card"
									data-category={photo.data.category || "General"}
								>
									<button
										type="button"
										class="photo-wrap"
										data-src={imgUrl}
										data-caption={photo.data.caption as string || ""}
										data-index={index}
										aria-label={`View ${photo.data.caption as string || "photo"} full size`}
									>
										<img
											src={imgUrl}
											alt={photo.data.caption as string || "Master Carpenters project photo"}
											loading="lazy"
											decoding="async"
										/>
										{photo.data.caption && (
											<span class="photo-caption">{photo.data.caption}</span>
										)}
									</button>
								</figure>
							);
						})}
					</div>
				</>
			) : (
				<div class="gallery-empty">
					<p>Photos will appear here once they've been uploaded to the media library.</p>
					<a href="/_emdash/admin" class="btn btn-primary" style="margin-top:1.5rem;">Upload Photos in Admin</a>
				</div>
			)}
		</div>
	</section>

	<!-- Lightbox injected via JS to avoid position:fixed stacking context traps -->

	<section class="gallery-cta section">
		<div class="container">
			<div class="cta-box">
				<h2>Like what you see?</h2>
				<p>Get a free estimate for your deck, siding, or exterior project.</p>
				<div class="cta-actions">
					<a href="/contact" class="btn btn-primary btn-lg">Get a Free Estimate</a>
					<a href="tel:3193604130" class="btn btn-secondary btn-lg">(319) 360-4130</a>
				</div>
			</div>
		</div>
	</section>
</Base>

<script>
	// ── Filter bar ──────────────────────────────────────────────
	const filterBar = document.getElementById("filter-bar");
	const grid = document.getElementById("photo-grid");
	if (filterBar && grid) {
		filterBar.addEventListener("click", (e) => {
			const btn = (e.target as HTMLElement).closest<HTMLButtonElement>(".filter-btn");
			if (!btn) return;
			filterBar.querySelectorAll(".filter-btn").forEach((b) => b.classList.remove("active"));
			btn.classList.add("active");
			const cat = btn.dataset.category;
			grid.querySelectorAll<HTMLElement>(".photo-card").forEach((card) => {
				const show = cat === "All" || card.dataset.category === cat;
				card.style.display = show ? "" : "none";
			});
		});
	}

	// ── Lightbox — injected onto body to avoid stacking context traps ──
	const lb = document.createElement("div");
	lb.id = "lightbox";
	lb.setAttribute("role", "dialog");
	lb.setAttribute("aria-modal", "true");
	lb.setAttribute("aria-label", "Image lightbox");
	lb.innerHTML = `
		<button class="lb-close" id="lb-close" aria-label="Close lightbox">&times;</button>
		<button class="lb-prev" id="lb-prev" aria-label="Previous image">&#8249;</button>
		<button class="lb-next" id="lb-next" aria-label="Next image">&#8250;</button>
		<div class="lb-inner">
			<img id="lb-img" src="" alt="" />
			<p id="lb-caption" class="lb-caption"></p>
		</div>
	`;
	lb.style.cssText = `
		display: none;
		position: fixed;
		inset: 0;
		z-index: 9999;
		background: rgba(0,0,0,0.92);
		align-items: center;
		justify-content: center;
	`;
	document.body.appendChild(lb);

	const lbImg = document.getElementById("lb-img") as HTMLImageElement;
	const lbCaption = document.getElementById("lb-caption")!;
	const lbClose = document.getElementById("lb-close")!;
	const lbPrev = document.getElementById("lb-prev")!;
	const lbNext = document.getElementById("lb-next")!;

	// Style the lightbox elements via inline styles (no Astro scoped CSS needed)
	const style = document.createElement("style");
	style.textContent = `
		#lightbox { display: none; }
		#lightbox.open { display: flex !important; }
		.lb-inner {
			position: relative;
			max-width: 90vw;
			max-height: 90vh;
			display: flex;
			flex-direction: column;
			align-items: center;
		}
		.lb-inner img {
			max-width: 90vw;
			max-height: 80vh;
			object-fit: contain;
			border-radius: 8px;
			display: block;
		}
		.lb-caption {
			color: rgba(255,255,255,0.8);
			font-size: 0.9rem;
			margin-top: 0.75rem;
			text-align: center;
			min-height: 1.5em;
		}
		.lb-close {
			position: fixed;
			top: 1rem;
			right: 1.5rem;
			background: none;
			border: none;
			color: #fff;
			font-size: 2.5rem;
			line-height: 1;
			cursor: pointer;
			opacity: 0.8;
			z-index: 10000;
		}
		.lb-close:hover { opacity: 1; }
		.lb-prev, .lb-next {
			position: fixed;
			top: 50%;
			transform: translateY(-50%);
			background: rgba(255,255,255,0.1);
			border: none;
			color: #fff;
			font-size: 3rem;
			line-height: 1;
			padding: 0.5rem 1rem;
			cursor: pointer;
			border-radius: 6px;
			transition: background 0.2s;
			z-index: 10000;
		}
		.lb-prev { left: 1rem; }
		.lb-next { right: 1rem; }
		.lb-prev:hover, .lb-next:hover { background: rgba(255,255,255,0.25); }
	`;
	document.head.appendChild(style);

	let currentIndex = 0;

	function getVisibleTiles(): HTMLButtonElement[] {
		return Array.from(
			document.querySelectorAll<HTMLButtonElement>(".photo-card:not([style*='display: none']) .photo-wrap")
		);
	}

	function openLightbox(btn: HTMLButtonElement) {
		const tiles = getVisibleTiles();
		currentIndex = tiles.indexOf(btn);
		showSlide(currentIndex, tiles);
		lb.classList.add("open");
		document.body.style.overflow = "hidden";
		lbClose.focus();
	}

	function closeLightbox() {
		lb.classList.remove("open");
		document.body.style.overflow = "";
	}

	function showSlide(index: number, tiles?: HTMLButtonElement[]) {
		const t = tiles || getVisibleTiles();
		if (!t.length) return;
		currentIndex = (index + t.length) % t.length;
		const btn = t[currentIndex];
		lbImg.src = btn.dataset.src || "";
		lbImg.alt = btn.dataset.caption || "Master Carpenters project photo";
		lbCaption.textContent = btn.dataset.caption || "";
		lbPrev.style.display = t.length > 1 ? "" : "none";
		lbNext.style.display = t.length > 1 ? "" : "none";
	}

	document.querySelectorAll<HTMLButtonElement>(".photo-wrap").forEach((btn) => {
		btn.addEventListener("click", () => openLightbox(btn));
	});

	lbClose.addEventListener("click", closeLightbox);
	lb.addEventListener("click", (e) => { if (e.target === lb) closeLightbox(); });
	lbPrev.addEventListener("click", () => showSlide(currentIndex - 1));
	lbNext.addEventListener("click", () => showSlide(currentIndex + 1));

	document.addEventListener("keydown", (e) => {
		if (!lb.classList.contains("open")) return;
		if (e.key === "Escape") closeLightbox();
		if (e.key === "ArrowLeft") showSlide(currentIndex - 1);
		if (e.key === "ArrowRight") showSlide(currentIndex + 1);
	});
</script>

<style>
	.gallery-hero { padding-bottom: 0; }

	.filter-bar {
		display: flex;
		flex-wrap: wrap;
		gap: var(--spacing-sm);
		justify-content: center;
		margin-bottom: var(--spacing-2xl);
	}

	.filter-btn {
		padding: var(--spacing-xs) var(--spacing-md);
		background: transparent;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-full, 999px);
		font-family: var(--font-body);
		font-size: var(--font-size-sm);
		font-weight: 500;
		color: var(--color-muted);
		cursor: pointer;
		transition: all var(--transition-fast);
	}

	.filter-btn:hover,
	.filter-btn.active {
		background: var(--color-brand);
		border-color: var(--color-brand);
		color: #fff;
	}

	.photo-grid {
		columns: 3 280px;
		column-gap: var(--spacing-md);
	}

	.photo-card {
		break-inside: avoid;
		margin-bottom: var(--spacing-md);
		border-radius: var(--radius-lg);
		overflow: hidden;
	}

	.photo-wrap {
		position: relative;
		display: block;
		width: 100%;
		overflow: hidden;
		border-radius: var(--radius-lg);
		background: var(--color-surface);
		cursor: zoom-in;
		border: none;
		padding: 0;
	}

	.photo-wrap img {
		width: 100%;
		height: auto;
		display: block;
		transition: transform 0.4s ease;
	}

	.photo-card:hover .photo-wrap img {
		transform: scale(1.03);
	}

	.photo-caption {
		position: absolute;
		bottom: 0;
		left: 0;
		right: 0;
		padding: var(--spacing-sm) var(--spacing-md);
		background: linear-gradient(to top, rgba(0,0,0,0.7), transparent);
		color: #fff;
		font-size: var(--font-size-sm);
		font-weight: 500;
		opacity: 0;
		transition: opacity 0.3s ease;
	}

	.photo-card:hover .photo-caption {
		opacity: 1;
	}

	/* ── Gallery empty / CTA ────────────────────────────────────── */
	.gallery-empty {
		text-align: center;
		padding: var(--spacing-5xl) 0;
		color: var(--color-muted);
	}

	.gallery-cta { padding-top: var(--spacing-3xl); }

	.cta-box {
		text-align: center;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		padding: var(--spacing-4xl);
	}

	.cta-box h2 {
		font-size: var(--font-size-3xl);
		font-weight: var(--font-weight-display);
		margin-bottom: var(--spacing-md);
	}

	.cta-box p {
		font-size: var(--font-size-lg);
		color: var(--color-muted);
		margin-bottom: var(--spacing-2xl);
	}

	.cta-actions {
		display: flex;
		gap: var(--spacing-md);
		justify-content: center;
		flex-wrap: wrap;
	}
</style>
